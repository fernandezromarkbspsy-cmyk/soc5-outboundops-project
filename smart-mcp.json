{
  "project_root": ".",
  "max_file_bytes": 524288,
  "max_search_results": 100,
  "max_command_output": 24000,
  "allow_memory_writes": true,
  "ignore_directories": [
    ".git",
    "node_modules",
    "vendor",
    "dist",
    "build",
    ".next",
    "coverage",
    ".cache"
  ],
  "denied_file_names": [
    ".env",
    ".env.local",
    ".env.production",
    ".env.development",
    "credentials.json",
    "service-account.json",
    "secrets.json"
  ],
  "allowed_extensions": [
    ".go",
    ".ts",
    ".tsx",
    ".js",
    ".jsx",
    ".json",
    ".md",
    ".sql",
    ".css",
    ".scss",
    ".html",
    ".yaml",
    ".yml",
    ".toml",
    ".txt"
  ],
  "checks": {
    "backend_test": {
      "directory": "backend",
      "command": ["go", "test", "./..."],
      "timeout_seconds": 180
    },
    "backend_vet": {
      "directory": "backend",
      "command": ["go", "vet", "./..."],
      "timeout_seconds": 180
    },
    "frontend_typecheck": {
      "directory": "frontend",
      "command": ["npm", "run", "typecheck", "--if-present"],
      "timeout_seconds": 180
    },
    "frontend_lint": {
      "directory": "frontend",
      "command": ["npm", "run", "lint", "--if-present"],
      "timeout_seconds": 180
    },
    "frontend_build": {
      "directory": "frontend",
      "command": ["npm", "run", "build"],
      "timeout_seconds": 300
    }
  }
}
