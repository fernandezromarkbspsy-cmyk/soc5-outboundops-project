APP_NAME="SOC 5 Outbound API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173
LOG_CHANNEL=stack
LOG_STACK=stderr,sentry_logs
DB_CONNECTION=pgsql
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require
SUPABASE_URL=https://your-project.supabase.co
# Preferred for current Supabase projects.
SUPABASE_PUBLISHABLE_KEY=
# Optional fallback for projects that still use the legacy JWT-based anon key.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
BACKROOM_INITIAL_PASSWORD=change-me-in-each-environment
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_ENABLE_LOGS=true
ADMIN_EMAILS=romark.fernandez@spxexpress.com
